# Application
APP_SECRET=your_jwt_secret_here
APP_API_URL=http://localhost:3333
APP_WEB_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:docker@localhost:5432/gobarber

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=

# Storage (disk | s3)
STORAGE_DRIVER=disk

# Mail (ethereal | ses)
MAIL_DRIVER=ethereal

# AWS (only if using s3/ses)
AWS_ACCESS_KEY=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
